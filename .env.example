# .env.example
# Copia este archivo a .env y configura tus claves

# ============================================================================
# API KEYS
# ============================================================================

# NewsAPI - Obtener en https://newsapi.org
# Gratuito: 100 requests/día
# Premium: Sin límite
NEWSAPI_KEY=abc123def456ghi789

# Polymarket API (Opcional - no requiere auth, pero aquí si es necesario)
# POLYMARKET_API_KEY=tu_clave_opcional

# ============================================================================
# DATABASE
# ============================================================================

# Ruta a la base de datos SQLite
DATABASE_PATH=data/dashboard.db

# ============================================================================
# LOGGING
# ============================================================================

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# STREAMLIT
# ============================================================================

# Tema del dashboard: light, dark
STREAMLIT_THEME=light

# Secreto para autenticación (si implementas)
# STREAMLIT_SECRET=tu_clave_secreta_aqui
